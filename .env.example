# Primary application database.
# Use PostgreSQL for both staging and production deployments.
# Supabase Postgres is the intended managed database target for low-cost VPS deployments.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aiproxy?schema=public"

# Session secret for JWT token signing.
# Generate a strong random secret (minimum 32 characters) for production.
# Example: openssl rand -base64 32
SESSION_SECRET="your-secret-key-here-change-in-production"

# Application URL (used for redirects and callbacks).
NEXTAUTH_URL="http://localhost:3000"

# Runtime configuration.
# - mock: Uses in-memory mock adapter for development.
# - cliproxyapiplus: Uses real CLIProxyAPIPlus management API.
RUNTIME_MODE="mock"
RUNTIME_ENDPOINT="http://localhost:8080"

# Platform admin emails (comma-separated for beta launch).
# Users with these emails will have platform admin access.
PLATFORM_ADMIN_EMAILS=""

# OpenAI API Key for proxying (for direct provider fallback, if enabled).
OPENAI_API_KEY="sk-..."

# Encryption key for AES-256-GCM (32-byte hex string).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"

# Stripe payment configuration.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
